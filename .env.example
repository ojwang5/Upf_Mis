# Email Configuration for 2FA via SendGrid SMTP
# Copy this file to .env and update values as needed

# SendGrid SMTP Host
EMAIL_HOST=smtp.sendgrid.net

# SendGrid SMTP Port (587 for TLS)
EMAIL_PORT=587

# SendGrid Username (always 'apikey')
EMAIL_HOST_USER=apikey

# SendGrid API Key
# Get this from https://app.sendgrid.com/settings/api_keys
EMAIL_HOST_PASSWORD=SG.your_sendgrid_api_key_here

# Default sender email address
DEFAULT_FROM_EMAIL=ojwangsamuel1@gmail.com

# Alternative: Set SENDGRID_API_KEY for easy reference
# SENDGRID_API_KEY=SG.your_sendgrid_api_key_here
