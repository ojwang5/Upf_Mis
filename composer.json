{
  "name": "upf/mdd-management-system",
  "description": "MDD Management System - scaffolded composer.json",
  "type": "project",
  "require": {
    "php": ">=7.4",
    "monolog/monolog": "^3.0",
    "guzzlehttp/guzzle": "^7.0",
    "vlucas/phpdotenv": "^5.5",
    "symfony/var-dumper": "^6.0"
  },
  "require-dev": {
    "phpunit/phpunit": "^9.5"
  },
  "autoload": {
    "psr-4": {
      "App\\\\": "src/"
    }
  },
  "config": {
    "preferred-install": "dist",
    "sort-packages": true
  }
}
